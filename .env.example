# Telegram
TELEGRAM_BOT_TOKEN=123456789:your-telegram-bot-token-here
ALLOWED_USER_IDS=your-telegram-user-id

# Gemini AI (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3-pro-preview
LLM_TEMPERATURE=0.9

# Brand
BRAND_NAME=AtlantaVPN
BRAND_URL=https://atlantavpn.example
CTA_TEXT=Ссылка в шапке профиля

# Video
VIDEO_WIDTH=720
VIDEO_HEIGHT=1280
FPS=30
MIN_DURATION_SECONDS=15
MAX_DURATION_SECONDS=25

# TTS — ElevenLabs основной (Dmitriy D. / Adam), Edge TTS автоматический fallback
DEFAULT_TTS_ENGINE=elevenlabs
DEFAULT_TTS_VOICE=ru-RU-DmitryNeural
DEFAULT_VOICE_GENDER=male
SPEECH_RATE=+5%
SPEECH_PITCH=+0Hz
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID_DMITRIY=your-dmitriy-voice-id-here
ELEVENLABS_VOICE_ID_ADAM=pNInz6obpgDQGcFmaJgB
ELEVENLABS_MODEL=eleven_multilingual_v2

# New Era: локальные ассеты
NEW_ASSETS_DIR=new_main_assets

# Деплой (см. README_CLOUDRUN_DEPLOY.md)
TG_PROXY_URL=
PUBLIC_BASE_URL=
WEBHOOK_SECRET=your-random-webhook-secret-here
PORT=8080
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id-here
GOOGLE_SERVICE_ACCOUNT_JSON=

# Пути
CACHE_DIR=cache
LOGS_DIR=logs
ASSETS_DIR=assets
SQLITE_PATH=cache/bot.sqlite3
